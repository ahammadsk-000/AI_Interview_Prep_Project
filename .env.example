# ─── App ───────────────────────────────────────────────
APP_NAME=PrepForge
ENVIRONMENT=development            # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ─── Security ──────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_ALGORITHM=HS256

# ─── Database ──────────────────────────────────────────
POSTGRES_USER=prepforge
POSTGRES_PASSWORD=prepforge
POSTGRES_DB=prepforge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Async driver for the app; Alembic derives a sync URL automatically.
DATABASE_URL=postgresql+asyncpg://prepforge:prepforge@localhost:5432/prepforge
# Optional read replica for analytics (falls back to primary if empty).
READ_DATABASE_URL=
# Connection pool (front with PgBouncer in production).
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SEC=1800

# ─── Caching ───────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=30

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── OAuth (Phase 1 scaffolding) ───────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# ─── AI / LLM (used from Phase 3) ──────────────────────
LLM_PROVIDER=ollama               # ollama | openai_compatible | vllm
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=llama3.1

# ─── Rate limiting ─────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120

# ─── Code execution (coding platform) ──────────────────
# Production: configure Judge0 and DISABLE local execution (untrusted code).
JUDGE0_URL=
JUDGE0_KEY=
ALLOW_LOCAL_CODE_EXECUTION=true
CODE_EXEC_TIMEOUT_SEC=8

# ─── Observability ─────────────────────────────────────
METRICS_ENABLED=true
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=prepforge-backend
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
